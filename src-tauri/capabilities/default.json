{
  "identifier": "default",
  "description": "Default capabilities for OpenTone",
  "windows": ["main"],
  "platforms": ["windows", "linux", "macOS", "android"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-read-text-file",
    "fs:allow-read-file",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "/storage/emulated/0/Music/**" },
        { "path": "/storage/emulated/0/Download/**" }
      ]
    }
  ]
}
